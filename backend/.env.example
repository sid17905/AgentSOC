OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

ABUSEIPDB_API_KEY=

SLACK_WEBHOOK_URL=

GITHUB_TOKEN=
GITHUB_REPO=your-org/csirt-incidents

# Automatic folder ingestion. Drop files into AUTO_INGEST_DIR and the backend
# will analyze them without using the upload UI.
AUTO_INGEST_ENABLED=false
AUTO_INGEST_DIR=samples/inbox
AUTO_INGEST_ARCHIVE_DIR=samples/processed
AUTO_INGEST_ERROR_DIR=samples/failed
AUTO_INGEST_INTERVAL_SECONDS=5
AUTO_INGEST_MAX_FILE_SIZE_BYTES=10485760
